rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Default deny ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Platform helpers ────────────────────────────────────────────────────

    // StockPot platform admin (operates the admin app at port 4200).
    // Checks the top-level /users/{uid} collection that Firebase Auth populates.
    function isPlatformAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // ─── Platform-level collections (admin app only) ─────────────────────────

    // Top-level users — Auth-linked profiles managed by the admin app.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isPlatformAdmin();
    }

    // Platform settings (appName, theme, feature flags, etc.)
    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if isPlatformAdmin();
    }

    // Top-level subscriptions — managed by the admin app.
    match /subscriptions/{subscriptionId} {
      allow read, write: if isPlatformAdmin();
    }

    // Top-level payment records — managed by the admin app.
    match /payments/{paymentId} {
      allow read, write: if isPlatformAdmin();
    }

    // ─── Restaurant tenant helpers ───────────────────────────────────────────

    // Returns the caller's user doc inside the restaurant, or an empty resource
    // if it doesn't exist (safe for use in read rules).
    function restaurantUser(restaurantId) {
      return exists(/databases/$(database)/documents/restaurants/$(restaurantId)/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/restaurants/$(restaurantId)/users/$(request.auth.uid)).data
        : {};
    }

    function userRole(restaurantId) {
      return restaurantUser(restaurantId).get('role', '');
    }

    // Caller belongs to this restaurant (any role).
    function isMember(restaurantId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/restaurants/$(restaurantId)/users/$(request.auth.uid));
    }

    // Caller has owner or franchisee role — full management access.
    function isManager(restaurantId) {
      return isMember(restaurantId) &&
        (userRole(restaurantId) == 'owner' || userRole(restaurantId) == 'franchisee');
    }

    // ─── Restaurant multi-tenant collection ──────────────────────────────────
    match /restaurants/{restaurantId} {

      // Restaurant profile doc — managers write, all members read.
      allow read: if isMember(restaurantId) || isPlatformAdmin();
      allow write: if isManager(restaurantId) || isPlatformAdmin();

      // Restaurant-scoped users (RBAC membership docs).
      match /users/{userId} {
        // Members can read their own doc; managers can read all.
        allow read: if (request.auth != null && request.auth.uid == userId) ||
                       isManager(restaurantId) ||
                       isPlatformAdmin();
        // Only managers and platform admins can create / update membership.
        allow write: if isManager(restaurantId) || isPlatformAdmin();
      }

      // Recipes — managers write, all members read (kitchen staff need read).
      match /recipes/{recipeId} {
        allow read: if isMember(restaurantId) || isPlatformAdmin();
        allow write: if isManager(restaurantId) || isPlatformAdmin();
      }

      // Raw materials — managers write, all members read.
      match /rawMaterials/{materialId} {
        allow read: if isMember(restaurantId) || isPlatformAdmin();
        allow write: if isManager(restaurantId) || isPlatformAdmin();
      }

      // Sub-components (intermediate recipes) — managers write, all members read.
      match /subComponents/{componentId} {
        allow read: if isMember(restaurantId) || isPlatformAdmin();
        allow write: if isManager(restaurantId) || isPlatformAdmin();
      }

      // Inventory records — managers write, all members read.
      match /inventory/{inventoryId} {
        allow read: if isMember(restaurantId) || isPlatformAdmin();
        allow write: if isManager(restaurantId) || isPlatformAdmin();
      }

      // Purchase orders — managers only.
      match /purchaseOrders/{poId} {
        allow read, write: if isManager(restaurantId) || isPlatformAdmin();
      }

      // Vendors — managers only.
      match /vendors/{vendorId} {
        allow read, write: if isManager(restaurantId) || isPlatformAdmin();
      }

      // Cost reports — managers only.
      match /costReports/{reportId} {
        allow read, write: if isManager(restaurantId) || isPlatformAdmin();
      }
    }
  }
}
