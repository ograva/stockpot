{
  "name": "stockpot",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve admin",
    "start:user": "ng serve user-app --port 4400",
    "start:all": "concurrently \"npm run start\" \"npm run start:user\"",
    "build": "ng build admin && ng build user-app",
    "build:admin": "ng build admin",
    "build:user": "ng build user-app",
    "watch": "ng build admin --watch --configuration development",
    "test": "ng test",
    "test:e2e:admin": "playwright test --config=playwright.config.admin.ts",
    "test:e2e:user": "playwright test --config=playwright.config.user.ts",
    "test:e2e": "npm run test:e2e:admin && npm run test:e2e:user",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm test && npm run test:e2e",
    "firebase:emulators": "npx firebase emulators:start --import=./emulator-data --export-on-exit",
    "firebase:emulators:export": "npx firebase emulators:export ./emulator-data --force",
    "firebase:emulators:kill": "pkill -f 'firebase.*emulators\\|cloud-firestore-emulator\\|cloud-storage-rules-runtime\\|ui_server' 2>/dev/null; pkill -f 'java.*emulator' 2>/dev/null; echo 'Emulator processes killed'",
    "firebase:emulators:restart": "npm run firebase:emulators:kill && sleep 2 && npm run firebase:emulators",
    "firebase:deploy": "npx firebase deploy",
    "dev": "concurrently -n admin,user,firebase -c cyan,green,yellow \"npm run start\" \"npm run start:user\" \"npm run firebase:emulators\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.4",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.4",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "angular-tabler-icons": "^3.26.0",
    "apexcharts": "^5.10.4",
    "firebase": "^11.10.0",
    "ng-apexcharts": "^2.3.0",
    "ngx-scrollbar": "^19.1.4",
    "rxjs": "~7.8.2",
    "sass": "1.81.0",
    "short-uuid": "^6.0.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.2",
    "@angular/cli": "~21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/date-fns": "^2.6.0",
    "@types/jasmine": "~4.3.0",
    "@types/node": "^22.19.15",
    "concurrently": "^9.1.0",
    "firebase-tools": "^14.27.0",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "playwright": "^1.58.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "wait-on": "^8.0.5"
  }
}
